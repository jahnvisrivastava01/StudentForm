@model StudentForm.ViewModel.StudentViewModel

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>

<form asp-action="Index" method="post">

    <div asp-validation-summary="All"></div>

    <div>
        <label>Name:</label>
        <input asp-for="Name" />
        <span asp-validation-for="Name"></span>
    </div>

    <br />

    <div>
        <label>Email:</label>
        <input asp-for="Email" />
        <span asp-validation-for="Email"></span>
    </div>

    <br />

    <div>
        <label>Age:</label>
        <input asp-for="Age" />
        <span asp-validation-for="Age"></span>
    </div>

    <br />

    <div>
        <label>Enrollment ID:</label>
        <input asp-for="EnrollmentId" />
        <span asp-validation-for="EnrollmentId"></span>
    </div>

    <br />

    <div>
        <label>Specialisation:</label>
        <input asp-for="Specialisation" />
        <span asp-validation-for="Specialisation"></span>
    </div>

    <br />

    <div>
        <label>Courses:</label>

        @for (int i = 0; i < Model.Courses.Count; i++)
        {
            <div>

                <input asp-for="Courses[i].isSelected" />

                <input asp-for="Courses[i].Id" type="hidden" />

                <label>
                    @Model.Courses[i].CourseName
                </label>

            </div>
        }

    </div>

    <br />

    <button type="submit">Submit</button>

    <br />
    <br />

    <label>Status :</label>

  

</form>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
}