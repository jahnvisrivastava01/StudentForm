@model StudentForm.Models.StudentModel

@{
    ViewData["Title"] = "Student Details";
}

<h2>Student Details</h2>

<form asp-action="Index" method="post">
    <div asp-validation-summary="All"></div>
    <div>
        <label>Name:</label>
        <input asp-for="Name" />
        <span asp-validation-for="Name" />
    </div>

    <br/>

    <div>
        <label>Age:</label>
        <input asp-for="Age" />
    </div>

    <br/>

    <div>
        <label>Course:</label>
        <input asp-for="Course" />
    </div>

    <br/>

    <div>
        <label>Enrollment ID:</label>
        <input asp-for="EnrollmentId" />
    </div>

    <br/>

    <div>
        <label>Specialisation:</label>
        <input asp-for="Specialisation" />
    </div>

    <br/>

    <button type="submit">Submit</button>

    <br /><br />

    <label>Status :</label>

    <input type="text"  readonly value="@Model?.Message" />
</form>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}