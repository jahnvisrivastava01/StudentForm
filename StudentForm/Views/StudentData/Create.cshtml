@using StudentForm.ViewModel
@model StudentViewModel

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>StudentModel</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Age" class="control-label"></label>
                <input asp-for="Age" class="form-control" />
                <span asp-validation-for="Age" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Course" class="control-label"></label>
                <input asp-for="Course" class="form-control" />
                <span asp-validation-for="Course" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="EnrollmentId" class="control-label"></label>
                <input asp-for="EnrollmentId" class="form-control" />
                <span asp-validation-for="EnrollmentId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Specialisation" class="control-label"></label>
                <input asp-for="Specialisation" class="form-control" />
                <span asp-validation-for="Specialisation" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Message" class="control-label"></label>
                <input asp-for="Message" class="form-control" />
                <span asp-validation-for="Message" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
            <h4>Select Courses</h4>

            @for (int i = 0; i < Model.Courses.Count; i++)
            {
                <div class="form-check">

                    <input type="hidden"
                           asp-for="Courses.ElementAt(i).Id" />

                    <input type="hidden"
                           asp-for="Courses.ElementAt(i).CourseName" />

                    <input class="form-check-input"
                           asp-for="Courses.ElementAt(i).isSelected" />

                    <label class="form-check-label">
                        @Model.Courses.ElementAt(i).CourseName
                    </label>

                </div>
            }
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>
