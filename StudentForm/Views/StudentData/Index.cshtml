@model IEnumerable<StudentForm.Models.StudentModel>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>

<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Name)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Email)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Age)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.EnrollmentId)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Specialisation)
            </th>

            <th>
                Courses
            </th>



            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Email)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Age)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.EnrollmentId)
                </td>

                <td>
                    @Html.DisplayFor(modelItem => item.Specialisation)
                </td>

                <td>
                    @string.Join(", ", item.Courses.Select(c => c.CourseName))
                </td>



                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    <a href="#"
                       class="detailsJsonBtn"
                       data-id="@item.Id">
                        Details JSON
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

<div class="modal fade" id="detailsModal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4>Student Details</h4>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered">
                    <tr>
                        <th>Name</th>
                        <td id="studentName"></td>
                    </tr>

                    <tr>
                        <th>Email</th>
                        <td id="studentEmail"></td>
                    </tr>

                    <tr>
                        <th>Age</th>
                        <td id="studentAge"></td>
                    </tr>

                    <tr>
                        <th>Enrollment ID</th>
                        <td id="studentEnrollment"></td>
                    </tr>

                    <tr>
                        <th>Specialisation</th>
                        <td id="studentSpecialisation"></td>
                    </tr>

                    <tr>
                        <th>Courses</th>
                        <td id="studentCourses"></td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script>
        $(".detailsJsonBtn").click(function(){
            var studentId=$(this).data("id");
            $.ajax({
                url:"/StudentData/JsonDetails/" + studentId,
                type:"GET",
                success:function(response){
                    $("#studentName").text(response.name);
                    $("#studentEmail").text(response.email);
                    $("#studentAge").text(response.age);
                    $("#studentEnrollment").text(response.enrollmentId);
                    $("#studentSpecialisation").text(response.specialisation);
                    $("#studentCourses").text(response.courses.join(","));

                    var myModal=new bootstrap.Modal(document.getElementById("detailsModal"));
                    myModal.show();
                }
            })
        });
    </script>
}